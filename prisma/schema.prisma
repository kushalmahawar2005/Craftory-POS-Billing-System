generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id                  String           @id @default(cuid())
  shopName            String
  ownerName           String
  email               String           @unique
  phone               String?
  subscriptionPlan    String           @default("FREE")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  businessType        String?
  gstin               String?
  gstRegistered       Boolean          @default(false)
  gstRegistrationType String?
  gstLegalName        String?
  gstTradeName        String?
  gstRegisteredOn     DateTime?
  language            String           @default("English")
  onboardingCompleted Boolean          @default(false)
  categories          Category[]
  customers           Customer[]
  products            Product[]
  purchaseOrders      PurchaseOrder[]
  sales               Sale[]
  preferences         ShopPreferences?
  stores              Store[]
  subscriptions       Subscription[]
  suppliers           Supplier[]
  users               User[]

  @@map("shops")
}

model Subscription {
  id        String   @id @default(cuid())
  plan      String
  status    String
  startDate DateTime
  endDate   DateTime
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Store {
  id        String  @id @default(cuid())
  name      String
  location  String?
  address   String?
  city      String?
  state     String?
  pincode   String?
  shopId    String
  managerId String?
  sales     Sale[]
  manager   User?   @relation("StoreManager", fields: [managerId], references: [id])
  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  users     User[]  @relation("StoreStaff")

  @@map("stores")
}

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  passwordHash  String
  role          Role               @default(CASHIER)
  phone         String?
  status        String             @default("Active")
  isVerified    Boolean            @default(false)
  createdAt     DateTime           @default(now())
  shopId        String
  storeId       String?
  sales         Sale[]
  performance   StaffPerformance[]
  managedStores Store[]            @relation("StoreManager")
  shop          Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  store         Store?             @relation("StoreStaff", fields: [storeId], references: [id])

  @@map("users")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  shopId      String
  color       String?
  createdAt   DateTime   @default(now())
  description String?
  icon        String?
  imageUrl    String?
  level       Int        @default(0)
  parentId    String?
  status      String     @default("ACTIVE")
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  shop        Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products    Product[]

  @@map("categories")
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  phone          String?
  email          String?
  address        String?
  shopId         String
  products       Product[]
  purchaseOrders PurchaseOrder[]
  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("suppliers")
}

model Product {
  id            String         @id @default(cuid())
  name          String
  description   String?
  barcode       String?
  sku           String?
  price         Float
  costPrice     Float?
  taxRate       Float          @default(0)
  stockQuantity Int            @default(0)
  imageUrl      String?
  createdAt     DateTime       @default(now())
  shopId        String
  categoryId    String?
  supplierId    String?
  inventoryLogs InventoryLog[]
  category      Category?      @relation(fields: [categoryId], references: [id])
  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  @@map("products")
}

model InventoryLog {
  id         String   @id @default(cuid())
  changeType String
  quantity   Int
  reason     String?
  createdAt  DateTime @default(now())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory_logs")
}

model Customer {
  id         String   @id @default(cuid())
  name       String
  phone      String
  email      String?
  totalSpent Float    @default(0)
  createdAt  DateTime @default(now())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales      Sale[]

  @@unique([shopId, phone])
  @@map("customers")
}

model Sale {
  id            String     @id @default(cuid())
  invoiceNumber String
  subtotal      Float
  tax           Float      @default(0)
  discount      Float      @default(0)
  total         Float
  paymentMethod String
  createdAt     DateTime   @default(now())
  shopId        String
  storeId       String?
  customerId    String?
  staffId       String
  items         SaleItem[]
  customer      Customer?  @relation(fields: [customerId], references: [id])
  shop          Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staff         User       @relation(fields: [staffId], references: [id])
  store         Store?     @relation(fields: [storeId], references: [id])

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float
  total     Float
  saleId    String
  productId String
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model PurchaseOrder {
  id          String         @id @default(cuid())
  totalAmount Float          @default(0)
  status      String
  createdAt   DateTime       @default(now())
  shopId      String
  supplierId  String
  items       PurchaseItem[]
  shop        Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier    Supplier       @relation(fields: [supplierId], references: [id])

  @@map("purchase_orders")
}

model PurchaseItem {
  id              String        @id @default(cuid())
  quantity        Int
  costPrice       Float
  purchaseOrderId String
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("purchase_items")
}

model StaffPerformance {
  id           String   @id @default(cuid())
  salesCount   Int      @default(0)
  totalRevenue Float    @default(0)
  date         DateTime @db.Date
  staffId      String
  staff        User     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@map("staff_performance")
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String?
  phone     String?
  token     String
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([phone, token])
  @@unique([email, token])
  @@map("verification_tokens")
}

model ShopPreferences {
  id                 String  @id @default(cuid())
  enableDiscounts    Boolean @default(true)
  additionalCharges  Boolean @default(true)
  soundNotifications Boolean @default(true)
  emailNotifications Boolean @default(false)
  invoicePdf         Boolean @default(false)
  shopId             String  @unique
  shop               Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_preferences")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  INVENTORY_CLERK
}

model BusinessType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}
